# Serveur
PORT=3001
NODE_ENV=development
CLIENT_URL=https://kekosan.com
TZ=Europe/Paris

# Base de données MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=kekosan_db

# Stripe
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# JWT (admin uniquement)
JWT_SECRET=REPLACE_ME_with_a_long_random_string
ADMIN_EMAIL=admin@kekosan.fr
ADMIN_PASSWORD_HASH=REPLACE_ME_with_bcrypt_hash

# Minimum de commande (en euros)
MIN_ORDER_AMOUNT=20

# Mail (Nodemailer)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
MAIL_FROM=noreply@kekosan.fr
